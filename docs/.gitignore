# See https://help.github.com/articles/ignoring-files for more about ignoring files.
#
# Temporary files generated by your text editor or operating system
# belong in git's global ignore instead:
# `$XDG_CONFIG_HOME/git/ignore` or `~/.config/git/ignore`

# The gem's root .gitignore ignores Gemfile.lock (correct for a library gem). But
# this is a real deployable app — commit its lock so the docs image installs the
# exact gem versions we tested, not whatever resolves fresh at build time (a
# newer transitive dependency with a breaking change can't silently break the
# build). The Dockerfile installs frozen-off because the phlex-forms path gem's
# git-ls-files digest floats across commits; every OTHER gem stays pinned.
!Gemfile.lock

# Ignore bundler config.
/.bundle

# Node modules (bun-installed daisyUI/tailwind toolchain — restored in CI/deploy).
/node_modules

# Ignore all environment files.
/.env*

# Ignore all logfiles and tempfiles.
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# Ignore pidfiles, but keep the directory.
/tmp/pids/*
!/tmp/pids/
!/tmp/pids/.keep

/public/assets

# Compiled Tailwind/daisyUI CSS — generated at build/deploy, not committed.
/app/assets/builds/*
!/app/assets/builds/.keep

# Ignore key files for decrypting credentials and more.
/config/*.key

